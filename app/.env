###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
RABBITMQ_SCHEME=amqp
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=app
RABBITMQ_PASSWORD=app
RABBITMQ_VHOST=%2f
MESSENGER_TRANSPORT_DSN=${RABBITMQ_SCHEME}://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}/messages
MESSENGER_EXCHANGE_NAME=logs.ingest
MESSENGER_ROUTING_KEY=logs.ingest
###< symfony/messenger ###

REDIS_URL=redis://redis:6379
